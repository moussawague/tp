<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    card_view:cardCornerRadius="16dp"
    card_view:cardElevation="8dp"
    android:layout_margin="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Détails du résident"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#333"
            android:paddingBottom="16dp"/>

        <TextView
            android:id="@+id/tvName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nom Prénom"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000"
            android:paddingBottom="8dp"/>

        <TextView
            android:id="@+id/tvFloor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Étage : 1"
            android:textSize="14sp"
            android:textColor="#666"
            android:paddingBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Appareils"
            android:textStyle="bold"
            android:textSize="16sp"
            android:paddingBottom="6dp"/>

        <TextView
            android:id="@+id/tvAppliances"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Liste appareils"
            android:textColor="#444"
            android:paddingBottom="12dp"/>

        <TextView
            android:id="@+id/tvTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Consommation totale"
            android:textStyle="bold"
            android:textColor="#1B1B38"
            android:textSize="18sp"
            android:gravity="end"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>